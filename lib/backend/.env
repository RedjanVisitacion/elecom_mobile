# =====================================================================
# This path is inside the Flutter app repo. Django does NOT load this file.
#
# Put ALL secrets ONLY here (run Django from this folder):
#   F:\elecom_web\backend\.env
#
# Required for Face++ + enrollment (never add FACEPP_* to Flutter/.env files):
#   FACEPP_API_KEY=
#   FACEPP_API_SECRET=
#   FACEPP_FACESET_OUTER_ID=elecom_voters
#   FACEPP_DUPLICATE_THRESHOLD=80
#   FACEPP_VERIFY_THRESHOLD=80
#
# If you previously stored API keys in this mobile repo file, rotate them
# in the Face++/Cloudinary consoles and update only backend/.env .
# =====================================================================
